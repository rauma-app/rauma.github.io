//ini di github

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid in [
        'al7pklcovEhT9Dfusg6diEmrzfO2'
      ];
    }

    match /listings/{listingId} {
      // Publik cuma bisa lihat yang statusnya "approved".
      // Pemilik selalu bisa lihat iklannya sendiri walau masih pending/ditolak.
      // Admin bisa lihat semua.
      allow read: if resource.data.status == 'approved'
                  || (request.auth != null && resource.data.ownerUid == request.auth.uid)
                  || isAdmin();

      // User biasa bikin listing baru -> otomatis masuk status 'pending'.
      // Kategori 'subsidi' dan 'jual_cepat' cuma boleh dibuat oleh admin.
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid
                    && (
                      request.resource.data.type in ['pribadi', 'perumahan']
                      || isAdmin()
                    )
                    && (
                      request.resource.data.status == 'pending'
                      || isAdmin()
                    );

      // Pemilik boleh edit isi iklannya SENDIRI, dan status otomatis balik
      // ke 'pending' tiap kali diedit -- tapi TIDAK BOLEH set status jadi
      // 'approved' sendiri (cuma admin yang bisa approve).
      // Admin bebas ubah apapun termasuk status (buat approve/reject).
      allow update: if request.auth != null && (
                      (resource.data.ownerUid == request.auth.uid
                       && request.resource.data.status != 'approved')
                      || isAdmin()
                    );

      allow delete: if request.auth != null
                    && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }
  }
}




// ini di firebase



rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    function isAdmin() {

      return request.auth != null && request.auth.uid in [

        'al7pklcovEhT9Dfusg6diEmrzfO2'

      ];

    }

    match /listings/{listingId} {

      // Publik cuma bisa lihat yang statusnya "approved".

      // Pemilik selalu bisa lihat iklannya sendiri walau masih pending/ditolak.

      // Admin bisa lihat semua.

      allow read: if resource.data.status == 'approved'

                  || (request.auth != null && resource.data.ownerUid == request.auth.uid)

                  || isAdmin();

      // User biasa bikin listing baru -> otomatis masuk status 'pending'.

      // Kategori 'subsidi' dan 'jual_cepat' cuma boleh dibuat oleh admin.

      allow create: if request.auth != null

                    && request.resource.data.ownerUid == request.auth.uid

                    && (

                      request.resource.data.type in ['pribadi', 'perumahan']

                      || isAdmin()

                    )

                    && (

                      request.resource.data.status == 'pending'

                      || isAdmin()

                    );

      // Pemilik boleh edit isi iklannya SENDIRI, dan status otomatis balik

      // ke 'pending' tiap kali diedit -- tapi TIDAK BOLEH set status jadi

      // 'approved' sendiri (cuma admin yang bisa approve).

      // Admin bebas ubah apapun termasuk status (buat approve/reject).

      allow update: if request.auth != null && (

                      (resource.data.ownerUid == request.auth.uid

                       && request.resource.data.status != 'approved')

                      || isAdmin()

                    );

      allow delete: if request.auth != null

                    && (resource.data.ownerUid == request.auth.uid || isAdmin());

    }

  }

}
